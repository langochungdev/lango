{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DictOver Desktop",
  "version": "0.1.0",
  "identifier": "com.dictover.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DictOver Settings",
        "width": 920,
        "height": 640,
        "resizable": false,
        "decorations": false,
        "skipTaskbar": true,
        "transparent": true,
        "center": true,
        "visibleOnAllWorkspaces": false
      },
      {
        "label": "popover",
        "title": "DictOver Popover",
        "url": "/?window=popover",
        "width": 360,
        "height": 300,
        "resizable": false,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": false,
        "skipTaskbar": true,
        "transparent": true,
        "shadow": false
      },
      {
        "label": "hotkey-indicator",
        "title": "DictOver Loading",
        "url": "/?window=hotkey-indicator",
        "width": 172,
        "height": 58,
        "resizable": false,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": false,
        "skipTaskbar": true,
        "transparent": true,
        "shadow": false,
        "focus": false
      },
      {
        "label": "ocr-overlay",
        "title": "DictOver OCR Overlay",
        "url": "/?window=ocr-overlay",
        "width": 800,
        "height": 600,
        "resizable": false,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": false,
        "skipTaskbar": true,
        "transparent": true,
        "shadow": false,
        "focus": true
      },
      {
        "label": "debug-log",
        "title": "DictOver Debug Logs",
        "url": "/?window=debug-log",
        "width": 760,
        "height": 520,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
