{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DictOver Desktop",
  "version": "0.1.0",
  "identifier": "com.dictover.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DictOver Settings",
        "width": 920,
        "height": 760,
        "resizable": true
      },
      {
        "label": "popover",
        "title": "DictOver Popover",
        "url": "/?window=popover",
        "width": 460,
        "height": 320,
        "resizable": false,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
