{
  "name": "dictover-desktop",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.25.0",
  "type": "module",
  "scripts": {
    "dev:desktop:win": "powershell -ExecutionPolicy Bypass -File scripts/dev.ps1",
    "build:installer:win": "powershell -ExecutionPolicy Bypass -File scripts/build-installer.ps1",
    "build:installer:win:full": "powershell -ExecutionPolicy Bypass -File scripts/build-installer.ps1 -Full",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "npm run test:integration",
    "test:integration": "vitest run",
    "test:e2e": "wdio run wdio.conf.ts",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test:python": "python -m pytest sidecar/tests/ -v",
    "test:all": "bash scripts/test-all.sh",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@tauri-apps/cli": "^2.10.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "@wdio/cli": "^9.18.0",
    "@wdio/local-runner": "^9.18.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.18.0",
    "@wdio/tauri-service": "^1.0.0-next.0",
    "@wdio/types": "^9.18.0",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "expect-webdriverio": "^5.4.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0",
    "vite": "^6.0.1",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "serialize-javascript": "^7.0.0"
  }
}
